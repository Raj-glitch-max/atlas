root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{go,py,rs}]
indent_size = 4

[*.md]
# Markdown uses trailing two-space for hard line breaks; preserve it.
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab
